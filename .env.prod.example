# Single-VPS production config. Copy to `.env`, fill in, then:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# DNS for DOMAIN must point at this host; open ports 80 + 443.

# Public hostname Caddy will obtain a TLS cert for.
DOMAIN=healthaccessmap.example.org

# Backend CORS allow-list. Behind Caddy the SPA is same-origin, but keep this set to the https
# origin as defense-in-depth (and required if you later split the API onto another host).
ALLOWED_ORIGINS=https://healthaccessmap.example.org

# Optional observability - left unset = no-op (see frontend/src/lib/observability.ts).
# VITE_SENTRY_DSN=
# VITE_ANALYTICS_URL=
