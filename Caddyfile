# Caddy auto-provisions a Let's Encrypt cert for $DOMAIN and adds HSTS. It reverse-proxies the
# nginx `web` service (same-origin /api preserved). See docker-compose.prod.yml.
{$DOMAIN} {
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	encode zstd gzip
	reverse_proxy web:80
}
