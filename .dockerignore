# Keep build contexts small + reproducible. NOTE: data/processed/metrics.parquet and
# frontend/public/{metrics.json,zcta_overview.geojson,zcta.pmtiles} are intentionally NOT ignored -
# the images need them (they are produced by `make data`).
.git
.venv
**/__pycache__
**/*.pyc
.pytest_cache
node_modules
frontend/node_modules
frontend/dist
data/raw
data/processed/*.parquet
!data/processed/metrics.parquet
*.log
.DS_Store
proj-ideas
